<%- include('partials/header') %>

<body class="bg-[#020617] text-[#f1f5f9] h-screen w-screen flex flex-col font-[sans-serif] overflow-hidden">

    <div id="divideModal" class="hidden fixed inset-0 bg-black/85 z-[1000] items-center justify-center backdrop-blur-[4px]">
        <div class="bg-[#161b22] p-[25px] rounded-[20px] w-[400px] border border-[#30363d] shadow-2xl">
            <h3 class="text-white text-lg font-bold mb-5">Divide Settings</h3>
            <div class="flex mb-5 border-b border-[#333]">
                <button onclick="switchMode('smart')" id="btnSmart" class="flex-1 p-2.5 text-white border-b-2 border-blue-500 font-semibold">Smart Mode</button>
                <button onclick="switchMode('range')" id="btnRange" class="flex-1 p-2.5 text-[#888] font-semibold">ID Range</button>
            </div>
            <div id="smartInputs">
                <label class="text-[#888] text-xs font-bold block mb-1">TOTAL PARTS</label>
                <input type="number" id="smartParts" value="3" class="w-full p-2.5 bg-[#0d1117] text-white border border-[#333] mb-4 outline-none rounded-md">
                <label class="text-[#888] text-xs font-bold block mb-1">ITEMS PER PART (N-1)</label>
                <input type="number" id="smartItems" value="4" class="w-full p-2.5 bg-[#0d1117] text-white border border-[#333] outline-none rounded-md">
            </div>
            <div id="rangeInputs" class="hidden space-y-2">
                <input type="text" id="rangeKey" placeholder="ID Key (e.g. id)" class="w-full p-2.5 bg-[#0d1117] text-white rounded-md border border-[#333]">
                <div class="flex gap-2">
                    <input type="text" id="rangeStart" placeholder="From ID" class="w-1/2 p-2.5 bg-[#0d1117] text-white rounded-md border border-[#333]">
                    <input type="text" id="rangeEnd" placeholder="To ID" class="w-1/2 p-2.5 bg-[#0d1117] text-white rounded-md border border-[#333]">
                </div>
            </div>
            <button onclick="executeDivideLogic()" class="w-full p-[15px] bg-[#2563eb] text-white font-bold rounded-xl mt-5 hover:bg-blue-500 transition-all shadow-lg">DIVIDE NOW</button>
            <button onclick="closeDivideModal()" class="w-full text-[#888] text-sm mt-3 hover:text-slate-400">Cancel</button>
        </div>
    </div>

    <div id="copy-toast" class="fixed bottom-14 right-6 bg-[#10b981] text-white font-black text-xs px-6 py-3 rounded-xl shadow-lg translate-y-24 opacity-0 transition-all duration-400 z-[1000]">
        <i class="fa-solid fa-circle-check mr-2"></i> COPIED!
    </div>


    <main class="flex-1 p-4 grid grid-cols-1 md:grid-cols-[1fr_auto_1fr] gap-4 items-stretch overflow-hidden">
        
        <div class="bg-slate-900/60 border border-white/5 rounded-2xl flex flex-col overflow-hidden min-h-0 relative h-full">
            <div class="px-6 py-3 border-b border-white/5 bg-white/5 flex justify-between items-center text-[10px] font-bold text-zinc-500 uppercase tracking-wider shrink-0">
                <span>Input Raw Data</span>
                <div class="flex gap-4 items-center">
                    <span class="text-zinc-700 select-none">|</span>
                    <button onclick="pasteFromClipboard()" class="text-blue-400 hover:text-blue-300 transition-colors"><i class="fa-solid fa-paste"></i> PASTE</button>
                    <button onclick="clearAll()" class="text-red-400 hover:text-red-300 transition-colors"><i class="fa-solid fa-trash-can"></i> CLEAR</button>
                </div>
            </div>
            
            <div class="flex-1 flex overflow-hidden relative min-h-0 w-full bg-[#090d16]">
                <div id="line-gutter" class="w-[50px] bg-[#05080f] py-4 text-right pr-3 font-mono text-[13px] text-slate-600 select-none border-r border-white/5 overflow-hidden leading-[22px]">1</div>
                <div id="editor-scroller" class="flex-1 relative overflow-auto custom-scroll h-full" onscroll="handleEditorScroll()">
                    <div id="error-layer" class="absolute top-0 left-0 w-full p-4 font-mono text-[13px] leading-[22px] whitespace-pre pointer-events-none text-transparent z-10 box-border min-h-full"></div>
                    <textarea id="json-input" oninput="runEditorEngine();" onscroll="handleEditorScroll()" spellcheck="false" class="absolute top-0 left-0 w-full p-4 bg-transparent text-slate-300 outline-none resize-none font-mono text-[13px] leading-[22px] whitespace-pre z-20 box-border min-h-full overflow-hidden" placeholder="// Paste messy JSON here..."></textarea>
                </div>
                <div class="absolute right-0 top-0 w-[6px] h-full pointer-events-none z-30">
                    <div id="radar-error-dot" class="absolute right-0 w-[6px] h-[6px] bg-red-500 shadow-[0_0_8px_#ef4444] rounded-full hidden"></div>
                </div>
            </div>
        </div>

        <div class="flex flex-row md:flex-col justify-center items-center gap-3 py-2 md:py-0 shrink-0">
            <button onclick="processJSONBackend('fix')" title="Smart Fix Engine" class="w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center text-white shadow-xl hover:scale-110 active:scale-95 transition-all"><i class="fa-solid fa-wand-magic-sparkles text-lg"></i></button>
            <button onclick="processJSONBackend('merge')" title="Force Merge" class="w-12 h-12 bg-zinc-800 hover:bg-zinc-700 rounded-xl flex items-center justify-center text-blue-400 border border-blue-900/30 transition-all active:scale-95"><i class="fa-solid fa-layer-group"></i></button>
            <button onclick="processJSONBackend('shuffle')" title="Shuffle Items" class="w-12 h-12 bg-zinc-800 hover:bg-zinc-700 rounded-xl flex items-center justify-center text-amber-400 border border-amber-900/30 transition-all active:scale-95"><i class="fa-solid fa-shuffle"></i></button>
            <button onclick="openDivideModal()" title="Divide JSON Array" class="w-12 h-12 bg-zinc-800 hover:bg-zinc-700 rounded-xl flex items-center justify-center text-green-600 border border-zinc-900/30 transition-all active:scale-95"><i class="fa-solid fa-columns"></i></button>
            <button onclick="processJSONBackend('minify')" title="Minify Raw String" class="w-12 h-12 bg-zinc-800 hover:bg-zinc-700 rounded-xl flex items-center justify-center text-zinc-400 transition-all active:scale-95"><i class="fa-solid fa-compress"></i></button>
        </div>

        <div class="bg-slate-900/60 border border-white/5 rounded-2xl flex flex-col overflow-hidden relative">
            <div class="px-6 py-3 border-b border-white/5 bg-white/5 flex justify-between items-center text-[10px] font-bold text-zinc-500 uppercase tracking-wider">
                <span>Sanitized Output</span>
                <div class="flex gap-3">
                    <button onclick="copyOutput()" id="copy-btn" class="text-blue-400 hover:text-blue-300 transition-colors"><i class="fa-solid fa-copy"></i> COPY</button>
                    <button onclick="downloadJSON()" class="text-emerald-400 hover:text-emerald-300 transition-colors"><i class="fa-solid fa-download"></i> DOWNLOAD</button>
                </div>
            </div>
            <div id="output-wrapper" class="flex-1 p-6 overflow-auto custom-scroll bg-slate-950/20">
                <pre id="json-output" class="font-mono text-sm leading-relaxed whitespace-pre"></pre>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>

    <script src="/js/app.js"></script>
</body>
</html>